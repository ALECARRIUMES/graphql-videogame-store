{
  "name": "graphql-videogame-store",
  "version": "1.0.0",
  "description": "GraphQL API for a video game store with consoles and games",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node prisma/seed.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@as-integrations/express4": "^1.1.0",
    "@prisma/client": "^6.0.0",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
